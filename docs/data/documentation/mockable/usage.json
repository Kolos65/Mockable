{"identifier":{"url":"doc:\/\/Mockable\/documentation\/Mockable\/Usage","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/mockable\/usage"]}],"hierarchy":{"paths":[["doc:\/\/Mockable\/documentation\/Mockable"]]},"seeAlsoSections":[{"title":"Guides","generated":true,"anchor":"Guides","identifiers":["doc:\/\/Mockable\/documentation\/Mockable\/Installation","doc:\/\/Mockable\/documentation\/Mockable\/Configuration"]}],"sections":[],"schemaVersion":{"patch":0,"minor":3,"major":0},"abstract":[{"type":"text","text":"Larn how to use "},{"inlineContent":[{"type":"text","text":"Mockable"}],"type":"strong"},{"type":"text","text":" to write readable and concise unit tests."}],"metadata":{"title":"Usage","modules":[{"name":"Mockable"}],"roleHeading":"Article","role":"article"},"kind":"article","primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"inlineContent":[{"type":"text","text":"Given a protocol annotated with the "},{"code":"@Mockable","type":"codeVoice"},{"type":"text","text":" macro:"}],"type":"paragraph"},{"type":"codeListing","code":["import Mockable","","@Mockable","protocol ProductService {","    var url: URL? { get set }","    func fetch(for id: UUID) async throws -> Product","    func checkout(with product: Product) throws","}"],"syntax":"swift"},{"inlineContent":[{"text":"A mock implementation named ","type":"text"},{"type":"codeVoice","code":"MockProductService"},{"text":" will be generated, that can be used in unit tests like this:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["import Mockable","","lazy var productService = MockProductService()","lazy var cartService = CartServiceImpl(productService: productService)","","func testCartService() async throws {","    let mockURL = URL(string: \"apple.com\")","    let mockError: ProductError = .notFound","    let mockProduct = Product(name: \"iPhone 15 Pro\")","","    given(productService)","        .fetch(for: .any).willReturn(mockProduct)","        .checkout(with: .any).willThrow(mockError)","","    try await cartService.checkout(with: mockProduct, using: mockURL)","","    verify(productService)","        .fetch(for: .value(mockProduct.id)).called(.atLeastOnce)","        .checkout(with: .value(mockProduct)).called(.once)","        .url(newValue: .value(mockURL)).setCalled(.once)","}"],"syntax":"swift"},{"type":"heading","level":2,"text":"Syntax","anchor":"Syntax"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Mockable","type":"text"}]},{"type":"text","text":" has a declarative syntax that utilizes builders to construct "},{"type":"codeVoice","code":"given"},{"type":"text","text":", "},{"type":"codeVoice","code":"when"},{"type":"text","text":", and "},{"type":"codeVoice","code":"verify"},{"type":"text","text":" clauses."},{"type":"text","text":" "},{"type":"text","text":"When constructing any of these clauses, you always follow the same syntax:"}],"type":"paragraph"},{"inlineContent":[{"type":"codeVoice","code":"clause type"},{"type":"text","text":"("},{"type":"codeVoice","code":"service"},{"type":"text","text":")."},{"type":"codeVoice","code":"function builder"},{"type":"text","text":"."},{"type":"codeVoice","code":"behavior builder"}],"type":"paragraph"},{"inlineContent":[{"text":"In the following example where we use the previously introduced product service:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["let id = UUID()","let error: ProductError = .notFound","","given(productService).fetch(for: .value(id)).willThrow(error)"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"We specify the following:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"codeVoice","code":"given"}]},{"type":"text","text":": we want to register "},{"type":"strong","inlineContent":[{"type":"text","text":"return values"}]}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"codeVoice","code":"(productService)"}],"type":"strong"},{"type":"text","text":": we specify what mockable service we want to register return values for"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"code":".fetch(for: .value(id))","type":"codeVoice"}]},{"type":"text","text":": we want to mock the "},{"type":"codeVoice","code":"fetch(for:)"},{"type":"text","text":" method and constrain our behavior on calls with matching "},{"type":"codeVoice","code":"id"},{"type":"text","text":" parameters"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"code":".willThrow(error)","type":"codeVoice"}]},{"text":": if ","type":"text"},{"type":"codeVoice","code":"fetch(for:)"},{"text":" is called with the specified parameter value, we want an ","type":"text"},{"type":"strong","inlineContent":[{"text":"error","type":"text"}]},{"text":" to be thrown","type":"text"}],"type":"paragraph"}]}]},{"type":"heading","level":2,"text":"Parameters","anchor":"Parameters"},{"inlineContent":[{"text":"Function builders have ","type":"text"},{"inlineContent":[{"type":"text","text":"all parameters"}],"type":"strong"},{"text":" from the original requirement but ","type":"text"},{"inlineContent":[{"type":"text","text":"encapsulate them"}],"type":"strong"},{"text":" within the ","type":"text"},{"isActive":true,"identifier":"https:\/\/kolos65.github.io\/Mockable\/documentation\/mockable\/parameter","type":"reference"},{"text":" type.","type":"text"},{"text":" ","type":"text"},{"text":"When constructing mockable clauses, you have to ","type":"text"},{"inlineContent":[{"type":"text","text":"specify parameter conditions"}],"type":"strong"},{"text":" for every parameter of a function. There are three available options:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"code":".any","type":"codeVoice"}]},{"type":"text","text":": Matches every call to the specified function, disregarding the actual parameter values."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"codeVoice","code":".value(Value)"}],"type":"strong"},{"text":": Matches to calls with an identical value in the specified parameter.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"codeVoice","code":".matching((Value) -> Bool)"}]},{"text":": Uses the provided closure to filter functions calls.","type":"text"}]}]}]},{"type":"aside","style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Computed properties have no parameters, but mutable properties get a "},{"type":"codeVoice","code":"(newValue:)"},{"type":"text","text":" parameter in function builders that can be used"},{"type":"text","text":" "},{"type":"text","text":"to constraint functionality on property assignment with a match condition. These "},{"type":"codeVoice","code":"newValue"},{"type":"text","text":" conditions will only effect the "},{"type":"codeVoice","code":"performOnGet"},{"type":"text","text":", "},{"type":"codeVoice","code":"performOnSet"},{"type":"text","text":", "},{"type":"codeVoice","code":"getCalled"},{"type":"text","text":" and "},{"type":"codeVoice","code":"setCalled"},{"type":"text","text":" "},{"type":"text","text":"clauses but will have no effect on return clauses."}]}]},{"inlineContent":[{"type":"text","text":"Here are examples of using different parameter conditions:"}],"type":"paragraph"},{"type":"codeListing","code":["\/\/ throw an error when `fetch(for:)` is called with `id`","given(productService).fetch(for: .value(id)).willThrow(error)","","\/\/ print \"Ouch!\" if product service is called with a product named \"iPhone 15 Pro\"","when(productService)","  .checkout(with: .matching { $0.name == \"iPhone 15 Pro\" })","  .perform { print(\"Ouch!\") }","","\/\/ assert if the fetch(for:) was called exactly once regardless of what id parameter it was called with","verify(productService).fetch(for: .any).called(.once)"],"syntax":"swift"},{"type":"heading","level":2,"text":"Given","anchor":"Given"},{"inlineContent":[{"text":"Return values can be specified using a ","type":"text"},{"code":"given(_ service:)","type":"codeVoice"},{"text":" clause. There are three return builders available:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"https:\/\/kolos65.github.io\/Mockable\/documentation\/mockable\/functionreturnbuilder\/willreturn(_:)","type":"reference"},{"text":": Will store the given return value and use it to mock subsequent calls.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"https:\/\/kolos65.github.io\/Mockable\/documentation\/mockable\/throwingfunctionreturnbuilder\/willthrow(_:)","isActive":true},{"type":"text","text":": Will store the given error and throw it in subsequent calls. Only available for throwing functions and properties."}]}]},{"content":[{"inlineContent":[{"identifier":"https:\/\/kolos65.github.io\/Mockable\/documentation\/mockable\/throwingfunctionreturnbuilder\/willproduce(_:)","type":"reference","isActive":true},{"text":": Will use the provided closure for mocking. The closure has the same signature as the mocked function, so for example a function that takes an integer returns a string and can throw will accept a closure of type ","type":"text"},{"type":"codeVoice","code":"(Int) throws -> String"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"https:\/\/kolos65.github.io\/Mockable\/documentation\/mockable\/throwingfunctionreturnbuilder\/willhandle(_:)","isActive":true},{"type":"text","text":": Registers a result type that automatically emits a value when successful or throws a failure."}]}]}]},{"inlineContent":[{"type":"text","text":"The provided return values are used up in FIFO order and the last one is always kept for any further calls. Here are examples of using return clauses:"}],"type":"paragraph"},{"type":"codeListing","code":["\/\/ Throw an error for the first call and then return 'product' for every other call","given(productService)","    .fetch(for: .any).willThrow(error)","    .fetch(for: .any).willReturn(product)","","\/\/ Throw an error if the id parameter ends with a 0, return a product otherwise","given(productService)","    .fetch(for: .any).willProduce { id in","        if id.uuidString.last == \"0\" {","            throw error","        } else {","            return product","        }","    }"],"syntax":"swift"},{"type":"heading","level":2,"text":"When","anchor":"When"},{"inlineContent":[{"type":"text","text":"Side effects can be added using "},{"code":"when(_ service:)","type":"codeVoice"},{"type":"text","text":" clauses. There are three kind of side effects:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"https:\/\/kolos65.github.io\/Mockable\/documentation\/mockable\/functionactionbuilder\/perform(_:)"},{"text":": Will register an operation to perform on invocations of the mocked function.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"https:\/\/kolos65.github.io\/Mockable\/documentation\/mockable\/propertyactionbuilder\/performonget(_:)"},{"text":": Available for mutable properties only, will perform the provided operation on property access.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"reference","identifier":"https:\/\/kolos65.github.io\/Mockable\/documentation\/mockable\/propertyactionbuilder\/performonset(_:)","isActive":true},{"type":"text","text":": Available for mutable properties only, will perform the provided operation on property assignment."}],"type":"paragraph"}]}]},{"inlineContent":[{"type":"text","text":"Some examples of using side effects are:"}],"type":"paragraph"},{"type":"codeListing","code":["\/\/ log calls to fetch(for:)","when(productService).fetch(for: .any).perform {","    print(\"fetch(for:) was called\")","}","","\/\/ log when url is accessed","when(productService).url().performOnGet {","    print(\"url accessed\")","}","","\/\/ log when url is set to nil","when(productService).url(newValue: .value(nil)).performOnSet {","    print(\"url set to nil\")","}"],"syntax":"swift"},{"type":"heading","level":2,"text":"Verify","anchor":"Verify"},{"inlineContent":[{"text":"You can verify invocations of your mock service using the ","type":"text"},{"code":"verify(_ service:)","type":"codeVoice"},{"text":" clause.","type":"text"}],"type":"paragraph"},{"type":"aside","style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Mockable"}]},{"type":"text","text":" supports both "},{"type":"emphasis","inlineContent":[{"text":"XCTest","type":"text"}]},{"type":"text","text":" and "},{"type":"emphasis","inlineContent":[{"text":"Swift Testing","type":"text"}]},{"type":"text","text":" by using Pointfree’s "},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/pointfreeco\/swift-issue-reporting"},{"type":"text","text":" to dynamically report test failures with the appropriate test framework."}]}]},{"inlineContent":[{"type":"text","text":"There are three kind of verifications:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"reference","identifier":"https:\/\/kolos65.github.io\/Mockable\/documentation\/mockable\/functionverifybuilder\/called(_:file:line:)","isActive":true},{"type":"text","text":": Asserts invocation count based on the given value."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/kolos65.github.io\/Mockable\/documentation\/mockable\/propertyverifybuilder\/getcalled(_:file:line:)","isActive":true,"type":"reference"},{"type":"text","text":": Available for mutable properties only, asserts property access count."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"https:\/\/kolos65.github.io\/Mockable\/documentation\/mockable\/propertyverifybuilder\/setcalled(_:file:line:)","type":"reference"},{"type":"text","text":": Available for mutable properties only, asserts property assignment count."}]}]}]},{"inlineContent":[{"type":"text","text":"Here are some example assertions:"}],"type":"paragraph"},{"type":"codeListing","code":["verify(productService)","    \/\/ assert fetch(for:) was called between 1 and 5 times","    .fetch(for: .any).called(.from(1, to: 5))","    \/\/ assert checkout(with:) was called between exactly 10 times","    .checkout(with: .any).called(10)","    \/\/ assert url property was accessed at least 2 times","    .url().get(.moreOrEqual(to: 2))","    \/\/ assert url property was never set to nil","    .url(newValue: .value(nil)).setCalled(.never)"],"syntax":"swift"},{"inlineContent":[{"text":"If you are testing asynchronous code and cannot write sync assertions you can use the async counterparts of the above verifications:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"https:\/\/kolos65.github.io\/Mockable\/documentation\/mockable\/functionverifybuilder\/calledeventually(_:before:file:line:)","type":"reference"},{"text":": Wait until timeout or invocation count satisfied.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"https:\/\/kolos65.github.io\/Mockable\/documentation\/mockable\/propertyverifybuilder\/getcalledeventually(_:before:file:line:)","isActive":true},{"type":"text","text":": Wait until timeout or property access count satisfied."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"https:\/\/kolos65.github.io\/Mockable\/documentation\/mockable\/propertyverifybuilder\/setcalledeventually(_:before:file:line:)"},{"type":"text","text":": Wait until timeout or property assignment count satisfied."}]}]}]},{"inlineContent":[{"type":"text","text":"Here are some examples of async verifications:"}],"type":"paragraph"},{"type":"codeListing","code":["await verify(productService)","    \/\/ assert fetch(for:) was called between 1 and 5 times before default timeout (1 second)","    .fetch(for: .any).calledEventually(.from(1, to: 5))","    \/\/ assert checkout(with:) was called between exactly 10 times before 3 seconds","    .checkout(with: .any).calledEventually(10, before: .seconds(3))","    \/\/ assert url property was accessed at least 2 times before default timeout (1 second)","    .url().getCalledEventually(.moreOrEqual(to: 2))","    \/\/ assert url property was set to nil once","    .url(newValue: .value(nil)).setCalledEventually(.once)"],"syntax":"swift"},{"type":"heading","level":2,"text":"Relaxed Mode","anchor":"Relaxed-Mode"},{"inlineContent":[{"text":"By default, you must specify a return value for all requirements; otherwise, a fatal error will be thrown. The reason for this is to aid in the discovery (and thus the verification) of every called function when writing unit tests.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"However, it is common to prefer avoiding this strict default behavior in favor of a more relaxed setting, where,","type":"text"},{"text":" ","type":"text"},{"text":"for example, void or optional return values do not need explicit ","type":"text"},{"code":"given","type":"codeVoice"},{"text":" registration.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Use the Use "},{"type":"reference","isActive":true,"identifier":"https:\/\/kolos65.github.io\/Mockable\/documentation\/mockable\/mockerpolicy"},{"type":"text","text":" (which is an "},{"type":"reference","isActive":true,"identifier":"https:\/\/developer.apple.com\/documentation\/swift\/optionset"},{"type":"text","text":") to implicitly mock:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"only one kind of return value: "},{"type":"codeVoice","code":".relaxedMocked"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"construct a custom set of policies: "},{"type":"codeVoice","code":"[.relaxedVoid, .relaxedOptional]"}]}]},{"content":[{"inlineContent":[{"text":"or opt for a fully relaxed mode: ","type":"text"},{"code":".relaxed","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]}]},{"inlineContent":[{"text":"You have two options to override the default strict behavior of the library:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"At "},{"inlineContent":[{"type":"text","text":"mock implementation level"}],"type":"strong"},{"type":"text","text":" you can override the mocker policy for each individual mock implementation in the initializer:"}]},{"type":"codeListing","code":["let relaxedMock = MockService(policy: [.relaxedOptional, .relaxedVoid])"],"syntax":"swift"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"At ","type":"text"},{"inlineContent":[{"text":"project level","type":"text"}],"type":"strong"},{"text":" you can set a custom default policy to use in every scenario by changing the default property of ","type":"text"},{"inlineContent":[{"type":"text","text":"MockerPolicy"}],"type":"strong"},{"text":":","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["MockerPolicy.default = .relaxedVoid"]}]}]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":".relaxedMocked","type":"codeVoice"},{"text":" policy in combination with the ","type":"text"},{"isActive":true,"identifier":"https:\/\/kolos65.github.io\/Mockable\/documentation\/mockable\/mocked","type":"reference"},{"text":" protocol can be used to set an implicit return value for custom (or even built in) types:","type":"text"}]},{"code":["struct Car {","    var name: String","    var seats: Int","}","","extension Car: Mocked {","    static var mock: Car {","        Car(name: \"Mock Car\", seats: 4)","    }","","    \/\/ Defaults to [mock] but we can ","    \/\/ provide a custom array of cars:","    static var mocks: [Car] {","        [","            Car(name: \"Mock Car 1\", seats: 4),","            Car(name: \"Mock Car 2\", seats: 4)","        ]","    }","}","","@Mockable","protocol CarService {","    func getCar() -> Car","    func getCars() -> [Car]","}","","func testCarService() {","    func test() {","        let mock = MockCarService(policy: .relaxedMocked)","        \/\/ Implictly mocked without a given registration:","        let car = mock.getCar()","        let cars = mock.getCars()","    }","}"],"type":"codeListing","syntax":"swift"},{"name":"Note","style":"note","type":"aside","content":[{"inlineContent":[{"type":"text","text":"⚠️ Relaxed mode will not work with generic return values as the type system is unable to locate the appropriate generic overload."}],"type":"paragraph"}]},{"text":"Working with non-equatable Types","level":2,"type":"heading","anchor":"Working-with-non-equatable-Types"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Mockable"}],"type":"strong"},{"text":" uses a ","type":"text"},{"identifier":"https:\/\/kolos65.github.io\/Mockable\/documentation\/mockable\/matcher","type":"reference","isActive":true},{"text":" internally to compare parameters.","type":"text"},{"text":" ","type":"text"},{"text":"By default the matcher is able to compare any custom type that conforms to ","type":"text"},{"type":"codeVoice","code":"Equatable"},{"text":" (except when used in a generic function).","type":"text"},{"text":" ","type":"text"},{"text":"In special cases, when you","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"have non-equatable parameter types"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"need testing specific equality logic for a custom type"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"have generic functions that are used with custom concrete types"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"you can register your custom types with the "},{"code":"Matcher.register()","type":"codeVoice"},{"type":"text","text":" functions."},{"type":"text","text":" "},{"type":"text","text":"Here is how to do it:"}]},{"code":["\/\/ register an equatable type to the matcher because we use it in a generic function","Matcher.register(SomeEquatableType.self)","","\/\/ register a non-equatable type to the matcher","Matcher.register(Product.self, match: { $0.name == $1.name })","","\/\/ register a meta-type to the matcher","Matcher.register(HomeViewController.Type.self)","","\/\/ remove all previously registered custom types","Matcher.reset()"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you see this error during tests:"}]},{"code":["No comparator found for type XYZ. All non-equatable types must be ","registered using Matcher.register(_)."],"type":"codeListing","syntax":null},{"type":"paragraph","inlineContent":[{"text":"remember to add the noted type to your ","type":"text"},{"code":"Matcher","type":"codeVoice"},{"text":" using the ","type":"text"},{"code":"register()","type":"codeVoice"},{"text":" function.","type":"text"}]}]}],"references":{"https://kolos65.github.io/Mockable/documentation/mockable/functionreturnbuilder/willreturn(_:)":{"titleInlineContent":[{"type":"codeVoice","code":"willReturn(_ value:)"}],"identifier":"https:\/\/kolos65.github.io\/Mockable\/documentation\/mockable\/functionreturnbuilder\/willreturn(_:)","url":"https:\/\/kolos65.github.io\/Mockable\/documentation\/mockable\/functionreturnbuilder\/willreturn(_:)","title":"willReturn(_ value:)","type":"link"},"https://kolos65.github.io/Mockable/documentation/mockable/propertyactionbuilder/performonget(_:)":{"titleInlineContent":[{"type":"codeVoice","code":"performOnGet(_ action:)"}],"identifier":"https:\/\/kolos65.github.io\/Mockable\/documentation\/mockable\/propertyactionbuilder\/performonget(_:)","url":"https:\/\/kolos65.github.io\/Mockable\/documentation\/mockable\/propertyactionbuilder\/performonget(_:)","title":"performOnGet(_ action:)","type":"link"},"https://developer.apple.com/documentation/swift/optionset":{"titleInlineContent":[{"type":"text","text":"option set"}],"identifier":"https:\/\/developer.apple.com\/documentation\/swift\/optionset","url":"https:\/\/developer.apple.com\/documentation\/swift\/optionset","title":"option set","type":"link"},"doc://Mockable/documentation/Mockable/Configuration":{"abstract":[{"type":"text","text":"Learn how to configure build settings so generated mock implementations are excluded from release builds."}],"kind":"article","type":"topic","title":"Configuration","identifier":"doc:\/\/Mockable\/documentation\/Mockable\/Configuration","role":"article","url":"\/documentation\/mockable\/configuration"},"https://kolos65.github.io/Mockable/documentation/mockable/throwingfunctionreturnbuilder/willthrow(_:)":{"titleInlineContent":[{"type":"codeVoice","code":"willThrow(_ error:)"}],"identifier":"https:\/\/kolos65.github.io\/Mockable\/documentation\/mockable\/throwingfunctionreturnbuilder\/willthrow(_:)","url":"https:\/\/kolos65.github.io\/Mockable\/documentation\/mockable\/throwingfunctionreturnbuilder\/willthrow(_:)","title":"willThrow(_ error:)","type":"link"},"https://kolos65.github.io/Mockable/documentation/mockable/propertyverifybuilder/setcalledeventually(_:befo